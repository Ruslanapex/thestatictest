const ORDER = ["comparer","overwhelmed","waiter","achiever","trapped","blank"];
const SHORT_NAME = {
  comparer:"Comparer", overwhelmed:"Overwhelmed", waiter:"Perfectionist Waiter",
  achiever:"Empty Achiever", trapped:"Trapped", blank:"Blank Slate"
};

function markDots(color){
  const positions = [[32,10],[52,26],[46,50],[18,50],[12,26]];
  let dots = "", lines = "";
  positions.forEach((p,i)=>{
    dots += `<circle cx="${p[0]}" cy="${p[1]}" r="${i===0?4:2.4}" fill="${i===0?color:'#3a3d55'}"/>`;
    if(i>0){
      const prev = positions[i-1];
      lines += `<line x1="${prev[0]}" y1="${prev[1]}" x2="${p[0]}" y2="${p[1]}" stroke="#3a3d55" stroke-width="1"/>`;
    }
  });
  return `<circle cx="32" cy="32" r="30" stroke="#2b2d3f" stroke-width="1.2"/>${lines}${dots}`;
}

/* ============ STATE & LOGIC ============ */
let current = 0;
const answers = [];
let lastResult = null;

function buildProgress(){
  const el = document.getElementById('progress');
  el.innerHTML = '';
  QUESTIONS.forEach(()=>{
    const d = document.createElement('div');
    d.className = 'dot';
    el.appendChild(d);
  });
}
function updateProgress(){
  const dots = document.querySelectorAll('#progress .dot');
  dots.forEach((d,i)=>{
    d.classList.remove('done','current');
    if(i < current) d.classList.add('done');
    else if(i === current) d.classList.add('current');
  });
}
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('progress').style.display = (id === 'screen-quiz') ? 'flex' : 'none';
}
function startQuiz(){
  current = 0; answers.length = 0;
  buildProgress(); showScreen('screen-quiz'); renderQuestion();
}
function renderQuestion(){
  const q = QUESTIONS[current];
  document.getElementById('q-label').textContent = `Question ${current+1} of ${QUESTIONS.length}`;
  document.getElementById('q-text').textContent = q.text;
  const opts = document.getElementById('q-options');
  opts.innerHTML = '';
  q.options.forEach(opt=>{
    const btn = document.createElement('button');
    btn.className = 'option';
    btn.textContent = opt.t;
    btn.onclick = ()=> selectAnswer(opt.k);
    opts.appendChild(btn);
  });
  document.getElementById('back-btn').disabled = (current === 0);
  updateProgress();
}
function selectAnswer(key){
  answers[current] = key;
  if(current < QUESTIONS.length - 1){ current++; renderQuestion(); }
  else { finishQuiz(); }
}
function goBack(){ if(current > 0){ current--; renderQuestion(); } }

function scoreBreakdown(){
  const counts = {}; ORDER.forEach(k=>counts[k]=0);
  answers.forEach(k=>{ counts[k] = (counts[k]||0)+1; });
  const total = answers.length;
  const pct = {};
  ORDER.forEach(k=> pct[k] = Math.round((counts[k]/total)*100));
  let best = ORDER[0];
  ORDER.forEach(k=>{ if(counts[k] > counts[best]) best = k; });
  return { pct, best };
}

function finishQuiz(){
  const { pct, best } = scoreBreakdown();
  lastResult = { key: best, pct };
  const r = RESULTS[best];

  document.getElementById('result-mark').innerHTML = markDots(r.color);
  document.getElementById('result-title').textContent = r.title;
  document.getElementById('result-sub').textContent = r.sub;
  document.getElementById('result-body').innerHTML = r.body;
  document.getElementById('offer-title').textContent = r.offerTitle;
  document.getElementById('cta-btn').href = CHECKOUT_LINKS[best];

  const tonightList = document.getElementById('tonight-list');
  tonightList.innerHTML = '';
  r.tonight.forEach(item=>{
    const li = document.createElement('li');
    li.textContent = item;
    tonightList.appendChild(li);
  });

  const sorted = [...ORDER].sort((a,b)=> pct[b]-pct[a]).slice(0,3);
  const bars = document.getElementById('score-bars');
  bars.innerHTML = '';
  sorted.forEach((k,i)=>{
    const row = document.createElement('div');
    row.className = 'score-row';
    row.innerHTML = `
      <div class="score-name">${SHORT_NAME[k]}</div>
      <div class="score-track"><div class="score-fill ${i===0?'top':''}" style="width:0%"></div></div>
      <div class="score-pct">${pct[k]}%</div>
    `;
    bars.appendChild(row);
    setTimeout(()=>{ row.querySelector('.score-fill').style.width = pct[k]+'%'; }, 60);
  });

  showScreen('screen-result');
}
function restart(){ showScreen('screen-intro'); }

/* ============ SHARE CARD ============ */
function downloadCard(){
  if(!lastResult) return;
  const r = RESULTS[lastResult.key];
  const c = document.getElementById('shareCanvas');
  const ctx = c.getContext('2d');
  const W = c.width, H = c.height;

  ctx.fillStyle = '#12131c';
  ctx.fillRect(0,0,W,H);

  // subtle border
  ctx.strokeStyle = '#2b2d3f';
  ctx.lineWidth = 3;
  ctx.strokeRect(24,24,W-48,H-48);

  ctx.textAlign = 'center';
  ctx.fillStyle = '#8b7fd6';
  ctx.font = '600 28px Inter, sans-serif';
  ctx.fillText('WHAT\u2019S KEEPING YOU STUCK', W/2, 160);

  ctx.fillStyle = r.color;
  ctx.font = '600 76px Fraunces, serif';
  wrapText(ctx, r.title, W/2, 300, W-160, 84);

  ctx.fillStyle = '#9a97b3';
  ctx.font = '400 34px Inter, sans-serif';
  ctx.fillText(r.sub, W/2, 460);

  // score bars
  const sorted = [...ORDER].sort((a,b)=> lastResult.pct[b]-lastResult.pct[a]).slice(0,3);
  let y = 620;
  sorted.forEach((k,i)=>{
    ctx.textAlign = 'left';
    ctx.fillStyle = '#f2efe6';
    ctx.font = '500 30px Inter, sans-serif';
    ctx.fillText(SHORT_NAME[k], 140, y);

    ctx.fillStyle = '#2b2d3f';
    roundRect(ctx, 140, y+20, W-280, 22, 11); ctx.fill();

    const w = ((W-280) * lastResult.pct[k]) / 100;
    ctx.fillStyle = i===0 ? r.color : '#8b7fd6';
    roundRect(ctx, 140, y+20, Math.max(w,22), 22, 11); ctx.fill();

    ctx.textAlign = 'right';
    ctx.fillStyle = '#9a97b3';
    ctx.font = '400 26px Inter, sans-serif';
    ctx.fillText(lastResult.pct[k]+'%', W-140, y);

    y += 90;
  });

  ctx.textAlign = 'center';
  ctx.fillStyle = '#e8b84e';
  ctx.font = '600 30px Inter, sans-serif';
  ctx.fillText('Take the quiz \u2192 (link in bio)', W/2, H-100);

  const link = document.createElement('a');
  link.download = 'my-stuck-result.png';
  link.href = c.toDataURL('image/png');
  link.click();
}
function roundRect(ctx,x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}
function wrapText(ctx, text, x, y, maxWidth, lineHeight){
  const words = text.split(' ');
  let line = '', lines = [];
  words.forEach(w=>{
    const test = line + w + ' ';
    if(ctx.measureText(test).width > maxWidth && line !== ''){
      lines.push(line); line = w + ' ';
    } else { line = test; }
  });
  lines.push(line);
  const startY = y - ((lines.length-1) * lineHeight)/2;
  lines.forEach((l,i)=> ctx.fillText(l.trim(), x, startY + i*lineHeight));
}
