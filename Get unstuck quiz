<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>What's Actually Keeping You Stuck?</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#12131c;
    --bg-card:#1a1c29;
    --bg-card-hover:#212335;
    --border:#2b2d3f;
    --text:#f2efe6;
    --text-muted:#9a97b3;
    --accent:#e8b84e;
    --accent-soft:#3a3320;
    --violet:#8b7fd6;
    --radius:14px;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Inter',sans-serif;
    min-height:100vh;
    display:flex;
    align-items:center;
    justify-content:center;
    padding:24px;
    line-height:1.5;
  }
  .app{ width:100%; max-width:640px; }
  h1,h2,h3{ font-family:'Fraunces',serif; font-weight:600; letter-spacing:-0.01em; }

  .progress{ display:flex; gap:8px; justify-content:center; margin-bottom:36px; }
  .progress .dot{ width:8px; height:8px; border-radius:50%; background:var(--border); transition:background .3s ease, transform .3s ease; }
  .progress .dot.done{ background:var(--accent); }
  .progress .dot.current{ background:var(--violet); transform:scale(1.4); }

  .screen{ display:none; animation:fadeIn .4s ease; }
  .screen.active{ display:block; }
  @keyframes fadeIn{ from{opacity:0; transform:translateY(6px);} to{opacity:1; transform:translateY(0);} }

  .intro{ text-align:center; }
  .eyebrow{ font-size:13px; letter-spacing:.14em; text-transform:uppercase; color:var(--accent); margin-bottom:18px; font-weight:600; }
  .intro h1{ font-size:clamp(28px,5vw,40px); line-height:1.15; margin-bottom:18px; }
  .intro p{ color:var(--text-muted); font-size:16px; max-width:460px; margin:0 auto 32px; }
  .intro-mark{ margin:0 auto 24px; width:64px; height:64px; }
  .intro-note{ color:var(--text-muted); font-size:13px; margin-top:16px; }

  .btn{
    display:inline-flex; align-items:center; justify-content:center; gap:8px;
    background:var(--accent); color:#1a1206; font-family:'Inter',sans-serif; font-weight:700;
    font-size:16px; padding:16px 32px; border:none; border-radius:999px; cursor:pointer;
    transition:transform .15s ease, box-shadow .15s ease; text-decoration:none;
  }
  .btn:hover{ transform:translateY(-2px); box-shadow:0 8px 24px rgba(232,184,78,.25); }
  .btn:active{ transform:translateY(0); }
  .btn-secondary{
    background:transparent; border:1px solid var(--border); color:var(--text); font-weight:600;
    padding:14px 28px; border-radius:999px; cursor:pointer; font-family:'Inter',sans-serif; font-size:15px;
  }
  .btn-secondary:hover{ border-color:var(--violet); }

  .q-label{ font-size:13px; color:var(--text-muted); margin-bottom:10px; letter-spacing:.04em; text-transform:uppercase;}
  .q-text{ font-size:clamp(20px,3.6vw,26px); margin-bottom:28px; line-height:1.3; }
  .options{ display:flex; flex-direction:column; gap:10px; }
  .option{
    background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius);
    padding:16px 20px; text-align:left; color:var(--text); font-family:'Inter',sans-serif;
    font-size:15.5px; cursor:pointer; transition:border-color .15s ease, background .15s ease, transform .1s ease;
  }
  .option:hover{ background:var(--bg-card-hover); border-color:var(--violet); }
  .option:active{ transform:scale(.99); }

  .nav-row{ display:flex; justify-content:space-between; align-items:center; margin-top:28px; }
  .back-link{ color:var(--text-muted); font-size:14px; cursor:pointer; background:none; border:none; font-family:'Inter',sans-serif; }
  .back-link:hover{ color:var(--text); }
  .back-link:disabled{ opacity:0; pointer-events:none; }

  .result-mark{ width:72px; height:72px; margin:0 auto 20px; }
  .result-eyebrow{ text-align:center; color:var(--violet); font-size:13px; letter-spacing:.14em; text-transform:uppercase; font-weight:600; margin-bottom:10px;}
  .result-title{ text-align:center; font-size:clamp(30px,6vw,42px); margin-bottom:6px; }
  .result-sub{ text-align:center; color:var(--text-muted); font-size:14px; margin-bottom:26px; }

  .score-bars{ margin-bottom:26px; }
  .score-row{ display:flex; align-items:center; gap:12px; margin-bottom:10px; font-size:13px; }
  .score-name{ width:140px; color:var(--text-muted); flex-shrink:0; }
  .score-track{ flex:1; height:8px; background:var(--bg-card); border:1px solid var(--border); border-radius:99px; overflow:hidden; }
  .score-fill{ height:100%; border-radius:99px; background:var(--border); transition:width .8s ease; }
  .score-fill.top{ background:linear-gradient(90deg,var(--violet),var(--accent)); }
  .score-pct{ width:38px; text-align:right; color:var(--text-muted); flex-shrink:0; }

  .result-body{ background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:26px 24px; margin-bottom:18px; }
  .result-body p{ color:var(--text); font-size:15.5px; margin-bottom:14px; }
  .result-body p:last-child{ margin-bottom:0; }
  .result-body strong{ color:var(--accent); }

  .tonight-box{ background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:24px 24px; margin-bottom:18px; }
  .tonight-box h3{ font-size:15px; font-family:'Inter',sans-serif; font-weight:700; margin-bottom:14px; color:var(--text); }
  .tonight-box h3 span{ color:var(--accent); }
  .tonight-list{ list-style:none; display:flex; flex-direction:column; gap:12px; }
  .tonight-list li{ display:flex; gap:10px; font-size:14.5px; color:var(--text-muted); line-height:1.45; }
  .tonight-list li::before{ content:"→"; color:var(--violet); flex-shrink:0; font-weight:700; }

  .offer-box{ background:var(--accent-soft); border:1px solid rgba(232,184,78,.35); border-radius:var(--radius); padding:26px 24px; text-align:center; margin-bottom:18px; }
  .offer-box .offer-title{ font-size:17px; font-weight:600; margin-bottom:14px; }
  .offer-includes{ text-align:left; max-width:340px; margin:0 auto 18px; }
  .offer-includes li{ list-style:none; display:flex; gap:8px; font-size:14px; color:var(--text); margin-bottom:8px; }
  .offer-includes li::before{ content:"✓"; color:var(--accent); font-weight:700; flex-shrink:0; }
  .offer-box .price{ font-family:'Fraunces',serif; font-size:32px; color:var(--accent); margin:4px 0 16px;}
  .offer-box .price span{ font-size:15px; color:var(--text-muted); font-family:'Inter',sans-serif; text-decoration:line-through; margin-right:8px; }

  .share-row{ display:flex; gap:10px; justify-content:center; margin-bottom:10px; flex-wrap:wrap; }
  .retake-row{ text-align:center; margin-top:16px; }
  .retake-row button{ background:none; border:none; color:var(--text-muted); font-size:13px; cursor:pointer; text-decoration:underline; font-family:'Inter',sans-serif;}

  #shareCanvas{ display:none; }

  @media (max-width:480px){
    .offer-box, .result-body, .tonight-box{ padding:20px 18px; }
    .score-name{ width:110px; font-size:12px; }
  }
</style>
</head>
